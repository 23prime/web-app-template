#!/usr/bin/env bash
#MISE description="Run integration tests"
#MISE alias="it"
set -euo pipefail

BASE_URL="http://localhost:${PORT:-8080}"

echo "Starting database..."
docker compose up db -d --wait
echo

echo "Creating test database..."
docker compose exec -T db psql -U postgres -c "CREATE DATABASE app_test WITH TEMPLATE template0;" 2>/dev/null || true
echo


echo "Applying schema..."
(cd db && atlas schema apply --env test --config file://atlas.hcl --auto-approve)
echo

echo "Resetting test data..."
docker compose exec -T db psql -U postgres app_test -c "TRUNCATE TABLE users CASCADE;"
echo

echo "Starting server..."
(cd app && DATABASE_URL="${TEST_DATABASE_URL}" JWT_SECRET="${JWT_SECRET:-test-secret-for-integration-testing}" cargo run --bin server) &
SERVER_PID=$!
echo

trap 'kill "${SERVER_PID}" 2>/dev/null; docker compose stop db' EXIT

echo "Waiting for server to be ready..."
until curl -sf "${BASE_URL}/health" > /dev/null 2>&1; do
  sleep 0.5
done
echo "Server ready"
echo

echo "Running integration tests..."
runn run tests/runn/**/*.yml --runner "req:${BASE_URL}"
